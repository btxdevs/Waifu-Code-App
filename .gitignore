node_modules
out
dist
build
.vite-cache
*.log
.DS_Store

# Local design notes / parked ideas — never committed.
notes/

# Runtime chat saves + the per-chat reports they generate (user/session data).
saves/

# User-created characters (personal data; includes model copies + voice embeddings).
characters/

# Runtime long-term memory store (personal data the assistant remembers).
memory/

# Connection info Unity publishes at runtime for the app (port + per-session token).
app.connection.json

# Local LLM endpoint/model config (per-machine; holds keys/endpoints — not source).
llm.config.json

# Live app config (per-machine: workspace roots, fullAccess, autostart exePath…).
# The app runs on code defaults without it and writes its own; the tracked, documented
# template is app.config.example.json.
app.config.json

# Python
python/.venv/
python/__pycache__/
python/**/__pycache__/
python/app.log
*.pyc

# HF cache for STT (sherpa-onnx streaming Zipformer + silero_vad.onnx) and the
# pocket-tts bundles — see MODELS_DIR in app.py.
models/
